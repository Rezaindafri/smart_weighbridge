PROGRAM main
VAR_OUTPUT
    S1_LiDAR_Posisi : BOOL AT %QX0.1; (* TRUE jika LiDAR mendeteksi posisi truk sudah pas/pas di tengah. *)
    S2_LoadCell_Stable : BOOL AT %QX0.2; (* TRUE jika pembacaan berat dari load cell sudah stabil (tidak fluktuatif). *)
    Reset_Button : BOOL AT %QX0.3; (* Tombol untuk meriset sistem setelah truk selesai ditimbang dan keluar. *)
    PC_ANPR_Truk_Detected : BOOL AT %QX0.0; (* Diaktifkan oleh PC (Kamera) via Modbus jika plat nomor sukses terbaca. menggantikan S0_Truk_Masuk. *)
  END_VAR
  VAR
    LiDAR_Volume_Raw : UINT AT %QW20; (* Data raw volume dari LiDAR. *)
    LoadCell_Weight_Raw : UINT AT %QW21; (* Data raw berat dari Load Cell. *)
    Database_Tare_Weight : UINT AT %QW22; (* Data berat kosong truk yang dikirim oleh PC dari database. *)
    Sistem_Ready : BOOL; (* Lampu indikator jembatan timbang siap menerima truk. *)
    Alarm_Posisi : BOOL AT %QX0.6; (* Lampu/sirine jika truk berhenti di posisi yang salah. *)
    Density_Result : UINT AT %QW31; (* Hasil akhir perhitungan massa jenis (p). *)
    Netto_Weight : UINT AT %QW30; (* Hasil pengurangan berat total dengan berat kosong dari database. *)
    Palang_masuk : BOOL AT %QX0.4; (* palang fisik pengontrol antrian *)
    Lock_Data : BOOL AT %QX0.7; (* Relay internal untuk mengunci proses kalkulasi. *)
    Volume_Locked : UINT; (* Memori untuk menyimpan data volume yang sudah dikunci. *)
    Weight_Locked : UINT; (* Memori untuk menyimpan data berat yang sudah dikunci. *)
  END_VAR

